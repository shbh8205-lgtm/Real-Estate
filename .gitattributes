# Normalize line endings: Git stores text as LF, checks out native on each OS.
* text=auto

# Force LF for files that should always be LF regardless of platform
*.cs        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Windows-specific files keep CRLF
*.sln       text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf

# Treat as binary (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.mlnet     binary
*.docx      binary
*.dll       binary
*.pdb       binary
